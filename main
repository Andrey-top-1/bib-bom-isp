                BorderStyle = BorderStyle.FixedSingle
            };
            string defaultImg = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "images", "picture.png");
            if (File.Exists(defaultImg))
                pbImage.Image = Image.FromFile(defaultImg);
            btnLoadImage = new Button { Text = "Загрузить фото", Location = new Point(450, 260), Size = new Size(200, 30) };
            btnLoadImage.Click += BtnLoadImage_Click;

            btnSave = new Button { Text = "Сохранить", Location = new Point(150, y), Size = new Size(100, 40), BackColor = Color.LightGreen };
            btnSave.Click += BtnSave_Click;
            btnCancel = new Button { Text = "Отмена", Location = new Point(280, y), Size = new Size(100, 40) };
            btnCancel.Click += (s, e) => this.Close();
            btnDelete = new Button { Text = "Удалить", Location = new Point(410, y), Size = new Size(100, 40), BackColor = Color.LightCoral };
            btnDelete.Click += BtnDelete_Click;
            if (productId == 0) btnDelete.Visible = false;

            Controls.Add(lblTitle);
            Controls.Add(lblId); Controls.Add(txtId);
            Controls.Add(lblArticle); Controls.Add(txtArticle);
            Controls.Add(lblName); Controls.Add(txtName);
            Controls.Add(lblCategory); Controls.Add(cmbCategory);
            Controls.Add(lblDesc); Controls.Add(txtDescription);
            Controls.Add(lblFab); Controls.Add(cmbFabricator);
            Controls.Add(lblSup); Controls.Add(cmbSupplier);
            Controls.Add(lblUnit); Controls.Add(cmbUnit);
            Controls.Add(lblPrice); Controls.Add(numPrice);
            Controls.Add(lblCount); Controls.Add(numCount);
            Controls.Add(lblDiscount); Controls.Add(numDiscount);
            Controls.Add(pbImage); Controls.Add(btnLoadImage);
            Controls.Add(btnSave); Controls.Add(btnCancel); Controls.Add(btnDelete);
        }

        // Загрузка выпадающих списков из БД
        private void LoadCombo(ComboBox cmb, string table, string idField, string nameField)
        {
            using (SqlConnection conn = new SqlConnection(ConnString))
            {
                conn.Open();
                string sql = $"SELECT {idField}, {nameField} FROM {table}";
                using (SqlCommand cmd = new SqlCommand(sql, conn))
                using (SqlDataReader reader = cmd.ExecuteReader())
                {
                    var list = new System.Collections.ArrayList();
                    while (reader.Read())
                        list.Add(new { Id = reader.GetInt32(0), Name = reader.GetString(1) });
                    cmb.DataSource = list;
                    cmb.ValueMember = "Id";
                    cmb.DisplayMember = "Name";
                }
            }
        }

        // Загрузка данных товара при редактировании (с защитой от NULL)
        private void LoadProductData()
        {
            using (SqlConnection conn = new SqlConnection(ConnString))
            {
                conn.Open();
                string sql = "SELECT article, name, category_id, description, fabricator_id, supplier_id, unit_id, price, count, discount, photo_path FROM products WHERE product_id = @id";
                using (SqlCommand cmd = new SqlCommand(sql, conn))
                {
                    cmd.Parameters.AddWithValue("@id", productId);
                    using (SqlDataReader reader = cmd.ExecuteReader())
                    {
                        if (reader.Read())
                        {
                            txtId.Text = productId.ToString();
                            txtArticle.Text = reader.IsDBNull(0) ? "" : reader.GetString(0);
                            txtName.Text = reader.IsDBNull(1) ? "" : reader.GetString(1);
                            cmbCategory.SelectedValue = reader.GetInt32(2);
                            txtDescription.Text = reader.IsDBNull(3) ? "" : reader.GetString(3);
                            cmbFabricator.SelectedValue = reader.GetInt32(4);
                            cmbSupplier.SelectedValue = reader.GetInt32(5);
                            cmbUnit.SelectedValue = reader.GetInt32(6);
                            numPrice.Value = reader.GetDecimal(7);
                            numCount.Value = reader.GetInt32(8);
                            numDiscount.Value = reader.GetDecimal(9);
                            oldImagePath = reader.IsDBNull(10) ? null : reader.GetString(10);
                            if (oldImagePath != null)
                            {
                                string full = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, oldImagePath.Replace('/', '\\'));
                                if (File.Exists(full))
                                    pbImage.Image = Image.FromFile(full);
                            }
                        }
                    }
                }
            }
        }

        // Загрузка изображения с проверкой размера 300x200
        private void BtnLoadImage_Click(object sender, EventArgs e)
        {
            ofd.Filter = "Изображения|*.jpg;*.jpeg;*.png;*.bmp";
            if (ofd.ShowDialog() == DialogResult.OK)
            {
                using (var img = Image.FromFile(ofd.FileName))
                {
                    if (img.Width != 300 || img.Height != 200)
                    {
                        MessageBox.Show("Изображение должно быть размером 300x200 пикселей.", "Ошибка", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                        return;
                    }
                }
                pbImage.Image = Image.FromFile(ofd.FileName);
                newImageFileName = Path.GetFileName(ofd.FileName);
            }
        }

        // Сохранение товара (добавление или обновление)
        private void BtnSave_Click(object sender, EventArgs e)
        {
            if (string.IsNullOrWhiteSpace(txtArticle.Text) || string.IsNullOrWhiteSpace(txtName.Text))
            {
                MessageBox.Show("Заполните артикул и наименование.", "Ошибка", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }

            string imagePath = oldImagePath;
            if (newImageFileName != null)
            {
                string targetDir = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, "images");
                if (!Directory.Exists(targetDir))
                    Directory.CreateDirectory(targetDir);
                string targetPath = Path.Combine(targetDir, newImageFileName);
                File.Copy(ofd.FileName, targetPath, true);
                imagePath = $"images/{newImageFileName}";
                if (oldImagePath != null)
                {
                    string oldFull = Path.Combine(AppDomain.CurrentDomain.BaseDirectory, oldImagePath.Replace('/', '\\'));
                    if (File.Exists(oldFull))
                        File.Delete(oldFull);
                }
            }

            using (SqlConnection conn = new SqlConnection(ConnString))
            {
                conn.Open();
                if (productId == 0) // Добавление
                {
                    string sql = @"INSERT INTO products (article, name, category_id, description, fabricator_id, supplier_id, unit_id, price, count, discount, photo_path)
                                   VALUES (@art, @name, @cat, @desc, @fab, @sup, @unit, @price, @count, @disc, @photo)";
                    using (SqlCommand cmd = new SqlCommand(sql, conn))
                    {
                        cmd.Parameters.AddWithValue("@art", txtArticle.Text);
                        cmd.Parameters.AddWithValue("@name", txtName.Text);
                        cmd.Parameters.AddWithValue("@cat", (int)cmbCategory.SelectedValue);
                        cmd.Parameters.AddWithValue("@desc", txtDescription.Text);
                        cmd.Parameters.AddWithValue("@fab", (int)cmbFabricator.SelectedValue);
                        cmd.Parameters.AddWithValue("@sup", (int)cmbSupplier.SelectedValue);
                        cmd.Parameters.AddWithValue("@unit", (int)cmbUnit.SelectedValue);
                        cmd.Parameters.AddWithValue("@price", numPrice.Value);
                        cmd.Parameters.AddWithValue("@count", (int)numCount.Value);
                        cmd.Parameters.AddWithValue("@disc", numDiscount.Value);
                        cmd.Parameters.AddWithValue("@photo", imagePath != null ? (object)imagePath : DBNull.Value);
                        cmd.ExecuteNonQuery();
                        MessageBox.Show("Товар добавлен.", "Успех", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    }
                }
                else // Редактирование
                {
                    string sql = @"UPDATE products SET article=@art, name=@name, category_id=@cat, description=@desc, fabricator_id=@fab,
                                   supplier_id=@sup, unit_id=@unit, price=@price, count=@count, discount=@disc, photo_path=@photo
                                   WHERE product_id=@id";
                    using (SqlCommand cmd = new SqlCommand(sql, conn))
                    {
                        cmd.Parameters.AddWithValue("@id", productId);
                        cmd.Parameters.AddWithValue("@art", txtArticle.Text);
                        cmd.Parameters.AddWithValue("@name", txtName.Text);
                        cmd.Parameters.AddWithValue("@cat", (int)cmbCategory.SelectedValue);
                        cmd.Parameters.AddWithValue("@desc", txtDescription.Text);
                        cmd.Parameters.AddWithValue("@fab", (int)cmbFabricator.SelectedValue);
                        cmd.Parameters.AddWithValue("@sup", (int)cmbSupplier.SelectedValue);
                        cmd.Parameters.AddWithValue("@unit", (int)cmbUnit.SelectedValue);
                        cmd.Parameters.AddWithValue("@price", numPrice.Value);
                        cmd.Parameters.AddWithValue("@count", (int)numCount.Value);
                        cmd.Parameters.AddWithValue("@disc", numDiscount.Value);
                        cmd.Parameters.AddWithValue("@photo", imagePath != null ? (object)imagePath : DBNull.Value);
                        cmd.ExecuteNonQuery();
                        MessageBox.Show("Товар обновлён.", "Успех", MessageBoxButtons.OK, MessageBoxIcon.Information);
                    }
                }
            }
            this.Close();
        }

        // Удаление товара с проверкой наличия в заказах
        private void BtnDelete_Click(object sender, EventArgs e)
        {
            using (SqlConnection conn = new SqlConnection(ConnString))
            {
                conn.Open();
                string check = "SELECT COUNT(*) FROM orders_products WHERE product_id = @id";
                using (SqlCommand cmd = new SqlCommand(check, conn))
                {
                    cmd.Parameters.AddWithValue("@id", productId);
                    int cnt = (int)cmd.ExecuteScalar();
                    if (cnt > 0)
                    {
                        MessageBox.Show("Невозможно удалить товар: он присутствует в заказах.", "Ошибка", MessageBoxButtons.OK, MessageBoxIcon.Error);
                        return;
                    }
                }
                string del = "DELETE FROM products WHERE product_id = @id";
                using (SqlCommand cmd = new SqlCommand(del, conn))
                {
                    cmd.Parameters.AddWithValue("@id", productId);
                    cmd.ExecuteNonQuery();
                    MessageBox.Show("Товар удалён.", "Успех", MessageBoxButtons.OK, MessageBoxIcon.Information);
                }
            }
            this.Close();
        }
    }
}
Файл 4: OrdersForm.cs (исправлен)
csharp
using System;
using System.Collections.Generic;
using System.Data.SqlClient;
using System.Drawing;
using System.Windows.Forms;

namespace ExamApp
{
    public partial class OrdersForm : Form
    {
        private const string ConnString = "Data Source=YOUR_SERVER;Initial Catalog=DEE2;Integrated Security=True;Encrypt=False";
        private FlowLayoutPanel flowOrders;
        private List<Order> allOrders = new List<Order>();

        public OrdersForm()
        {
            this.Text = "Управление заказами";
            this.Size = new Size(1000, 700);
            this.StartPosition = FormStartPosition.CenterScreen;

            Panel top = new Panel { Dock = DockStyle.Top, Height = 50, BackColor = Color.LightSeaGreen };
            Button btnBack = new Button { Text = "Назад", Location = new Point(10, 10), Size = new Size(80, 30) };
            btnBack.Click += (s, e) => this.Close();
            Button btnAdd = new Button { Text = "Добавить заказ", Location = new Point(100, 10), Size = new Size(120, 30) };
            btnAdd.Visible = (UserSession.CurrentRole == UserSession.Role.admin);
            btnAdd.Click += (s, e) => { new OrderEditForm(0).ShowDialog(); LoadOrders(); };
            top.Controls.Add(btnBack);
            top.Controls.Add(btnAdd);

            flowOrders = new FlowLayoutPanel
            {
                Dock = DockStyle.Fill,
                AutoScroll = true,
                Padding = new Padding(10),
                FlowDirection = FlowDirection.TopDown,
                WrapContents = false
            };
            Controls.Add(flowOrders);
            Controls.Add(top);
            LoadOrders();
        }

        // Загрузка заказов из БД с защитой от NULL (например, delivery_date может быть NULL)
        private void LoadOrders()
        {
            allOrders.Clear();
            using (SqlConnection conn = new SqlConnection(ConnString))
            {
                conn.Open();
                string sql = @"SELECT o.order_id, o.order_date, o.delivery_date, o.pickup_point, o.status_id, os.name, 
                                      c.surname + ' ' + c.name + ' ' + c.patronymic 
                               FROM orders o
                               INNER JOIN order_statuses os ON os.status_id = o.status_id
                               INNER JOIN clients c ON c.client_id = o.client_id";
                using (SqlCommand cmd = new SqlCommand(sql, conn))
                using (SqlDataReader reader = cmd.ExecuteReader())
                {
                    while (reader.Read())
                    {
                        Order order = new Order();
                        order.Id = reader.GetInt32(0);
                        order.OrderDate = reader.GetDateTime(1);
                        order.DeliveryDate = reader.IsDBNull(2) ? (DateTime?)null : reader.GetDateTime(2);
                        order.PickupPoint = reader.IsDBNull(3) ? "" : reader.GetString(3);
                        order.StatusId = reader.GetInt32(4);
                        order.StatusName = reader.IsDBNull(5) ? "" : reader.GetString(5);
                        order.ClientFullName = reader.IsDBNull(6) ? "" : reader.GetString(6);
                        allOrders.Add(order);
                    }
                }
            }
            RenderOrders();
        }

        // Динамическое создание карточек заказов
        private void RenderOrders()
        {
            flowOrders.Controls.Clear();
            foreach (Order order in allOrders)
            {
                Panel card = new Panel { Width = flowOrders.Width - 25, Height = 120, Margin = new Padding(5), BorderStyle = BorderStyle.FixedSingle };
                Label lblId = new Label { Text = $"Заказ №{order.Id}", Font = new Font("Times New Roman", 12, FontStyle.Bold), Location = new Point(10, 5), Size = new Size(150, 25) };
                Label lblClient = new Label { Text = $"Клиент: {order.ClientFullName}", Location = new Point(10, 30), Size = new Size(300, 20) };
                Label lblDate = new Label { Text = $"Дата заказа: {order.OrderDate:dd.MM.yyyy}", Location = new Point(10, 55), Size = new Size(200, 20) };
                Label lblDelivery = new Label
                {
                    Text = order.DeliveryDate.HasValue ? $"Доставка: {order.DeliveryDate.Value:dd.MM.yyyy}" : "Доставка не назначена",
                    Location = new Point(10, 80),
                    Size = new Size(200, 20)
                };
                Label lblPoint = new Label { Text = $"Пункт выдачи: {order.PickupPoint}", Location = new Point(250, 30), Size = new Size(250, 20) };
                Label lblStatus = new Label { Text = $"Статус: {order.StatusName}", Location = new Point(250, 55), Size = new Size(200, 20), Font = new Font("Times New Roman", 10, FontStyle.Italic) };

                Button btnEdit = new Button { Text = "Редактировать", Location = new Point(600, 15), Size = new Size(120, 30) };
                btnEdit.Visible = (UserSession.CurrentRole == UserSession.Role.admin);
                btnEdit.Click += (s, e) => { new OrderEditForm(order.Id).ShowDialog(); LoadOrders(); };

                Button btnDelete = new Button { Text = "Удалить", Location = new Point(600, 55), Size = new Size(120, 30), BackColor = Color.LightCoral };
                btnDelete.Visible = (UserSession.CurrentRole == UserSession.Role.admin);
                btnDelete.Click += (s, e) =>
                {
                    if (MessageBox.Show("Удалить заказ?", "Подтверждение", MessageBoxButtons.YesNo, MessageBoxIcon.Question) == DialogResult.Yes)
                    {
                        using (SqlConnection conn = new SqlConnection(ConnString))
                        {
                            conn.Open();
                            string sql = "DELETE FROM orders WHERE order_id = @id";
                            using (SqlCommand cmd = new SqlCommand(sql, conn))
                            {
                                cmd.Parameters.AddWithValue("@id", order.Id);
                                cmd.ExecuteNonQuery();
                            }
                        }
                        LoadOrders();
                    }
                };

                card.Controls.Add(lblId);
                card.Controls.Add(lblClient);
                card.Controls.Add(lblDate);
                card.Controls.Add(lblDelivery);
                card.Controls.Add(lblPoint);
                card.Controls.Add(lblStatus);
                card.Controls.Add(btnEdit);
                card.Controls.Add(btnDelete);
                flowOrders.Controls.Add(card);
            }
        }
    }

    public class Order
    {
        public int Id { get; set; }
        public DateTime OrderDate { get; set; }
        public DateTime? DeliveryDate { get; set; }
        public string PickupPoint { get; set; }
        public int StatusId { get; set; }
        public string StatusName { get; set; }
        public string ClientFullName { get; set; }
    }

    public partial class OrderEditForm : Form
    {
        private const string ConnString = "Data Source=YOUR_SERVER;Initial Catalog=DEE2;Integrated Security=True;Encrypt=False";
        private int orderId;
        private ComboBox cmbStatus, cmbClient;
        private DateTimePicker dtpOrderDate, dtpDeliveryDate;
        private TextBox txtPickupPoint;
        private Button btnSave, btnCancel;

        public OrderEditForm(int id = 0)
        {
            orderId = id;
            this.Text = orderId > 0 ? "Редактирование заказа" : "Новый заказ";
            this.Size = new Size(500, 350);
            this.StartPosition = FormStartPosition.CenterScreen;
            this.FormBorderStyle = FormBorderStyle.FixedDialog;
            this.MaximizeBox = false;
            InitializeControls();
            if (orderId > 0)
                LoadOrderData();
        }

        private void InitializeControls()
        {
            int y = 20;
            Label lblOrderDate = new Label { Text = "Дата заказа:", Location = new Point(20, y), Size = new Size(100, 25) };
            dtpOrderDate = new DateTimePicker { Location = new Point(130, y), Size = new Size(200, 25), Format = DateTimePickerFormat.Short };
            y += 35;

            Label lblDelivery = new Label { Text = "Дата доставки:", Location = new Point(20, y), Size = new Size(100, 25) };
            dtpDeliveryDate = new DateTimePicker { Location = new Point(130, y), Size = new Size(200, 25), Format = DateTimePickerFormat.Short, ShowCheckBox = true, Checked = false };
            y += 35;

            Label lblPoint = new Label { Text = "Пункт выдачи:*", Location = new Point(20, y), Size = new Size(100, 25) };
            txtPickupPoint = new TextBox { Location = new Point(130, y), Size = new Size(200, 25) };
            y += 35;

            Label lblStatus = new Label { Text = "Статус:*", Location = new Point(20, y), Size = new Size(100, 25) };
            cmbStatus = new ComboBox { Location = new Point(130, y), Size = new Size(200, 25), DropDownStyle = ComboBoxStyle.DropDownList };
            LoadStatuses();
            y += 35;

            Label lblClient = new Label { Text = "Клиент:*", Location = new Point(20, y), Size = new Size(100, 25) };
            cmbClient = new ComboBox { Location = new Point(130, y), Size = new Size(200, 25), DropDownStyle = ComboBoxStyle.DropDownList };
            LoadClients();
            y += 45;

            btnSave = new Button { Text = "Сохранить", Location = new Point(100, y), Size = new Size(100, 35), BackColor = Color.LightGreen };
            btnSave.Click += BtnSave_Click;
            btnCancel = new Button { Text = "Отмена", Location = new Point(230, y), Size = new Size(100, 35) };
            btnCancel.Click += (s, e) => this.Close();

            Controls.Add(lblOrderDate); Controls.Add(dtpOrderDate);
            Controls.Add(lblDelivery); Controls.Add(dtpDeliveryDate);
            Controls.Add(lblPoint); Controls.Add(txtPickupPoint);
            Controls.Add(lblStatus); Controls.Add(cmbStatus);
            Controls.Add(lblClient); Controls.Add(cmbClient);
            Controls.Add(btnSave); Controls.Add(btnCancel);
        }

        private void LoadStatuses()
        {
            using (SqlConnection conn = new SqlConnection(ConnString))
            {
                conn.Open();
                string sql = "SELECT status_id, name FROM order_statuses";
                using (SqlCommand cmd = new SqlCommand(sql, conn))
                using (SqlDataReader reader = cmd.ExecuteReader())
                {
                    var list = new System.Collections.ArrayList();
                    while (reader.Read())
                        list.Add(new { Id = reader.GetInt32(0), Name = reader.GetString(1) });
                    cmbStatus.DataSource = list;
                    cmbStatus.ValueMember = "Id";
                    cmbStatus.DisplayMember = "Name";
                }
            }
        }

        private void LoadClients()
        {
            using (SqlConnection conn = new SqlConnection(ConnString))
            {
                conn.Open();
                string sql = "SELECT client_id, surname + ' ' + name + ' ' + patronymic as FullName FROM clients";
                using (SqlCommand cmd = new SqlCommand(sql, conn))
                using (SqlDataReader reader = cmd.ExecuteReader())
                {
                    var list = new System.Collections.ArrayList();
                    while (reader.Read())
                        list.Add(new { Id = reader.GetInt32(0), Name = reader.GetString(1) });
                    cmbClient.DataSource = list;
                    cmbClient.ValueMember = "Id";
                    cmbClient.DisplayMember = "Name";
                }
            }
        }

        // Загрузка данных заказа с защитой от NULL
        private void LoadOrderData()
        {
            using (SqlConnection conn = new SqlConnection(ConnString))
            {
                conn.Open();
                string sql = "SELECT order_date, delivery_date, pickup_point, status_id, client_id FROM orders WHERE order_id = @id";
                using (SqlCommand cmd = new SqlCommand(sql, conn))
                {
                    cmd.Parameters.AddWithValue("@id", orderId);
                    using (SqlDataReader reader = cmd.ExecuteReader())
                    {
                        if (reader.Read())
                        {
                            dtpOrderDate.Value = reader.GetDateTime(0);
                            if (!reader.IsDBNull(1))
                            {
                                dtpDeliveryDate.Value = reader.GetDateTime(1);
                                dtpDeliveryDate.Checked = true;
                            }
                            txtPickupPoint.Text = reader.IsDBNull(2) ? "" : reader.GetString(2);
                            cmbStatus.SelectedValue = reader.GetInt32(3);
                            cmbClient.SelectedValue = reader.GetInt32(4);
                        }
                    }
                }
            }
        }

        private void BtnSave_Click(object sender, EventArgs e)
        {
            if (string.IsNullOrWhiteSpace(txtPickupPoint.Text) || cmbStatus.SelectedValue == null || cmbClient.SelectedValue == null)
            {
                MessageBox.Show("Заполните все обязательные поля.", "Ошибка", MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return;
            }
            DateTime? delivery = dtpDeliveryDate.Checked ? (DateTime?)dtpDeliveryDate.Value : null;
            using (SqlConnection conn = new SqlConnection(ConnString))
            {
                conn.Open();
                if (orderId == 0)
                {
                    string sql = @"INSERT INTO orders (order_date, delivery_date, pickup_point, status_id, client_id)
                                   VALUES (@od, @dd, @pp, @sid, @cid)";
                    using (SqlCommand cmd = new SqlCommand(sql, conn))
                    {
                        cmd.Parameters.AddWithValue("@od", dtpOrderDate.Value);
                        cmd.Parameters.AddWithValue("@dd", delivery.HasValue ? (object)delivery.Value : DBNull.Value);
                        cmd.Parameters.AddWithValue("@pp", txtPickupPoint.Text);
                        cmd.Parameters.AddWithValue("@sid", (int)cmbStatus.SelectedValue);
                        cmd.Parameters.AddWithValue("@cid", (int)cmbClient.SelectedValue);
                        cmd.ExecuteNonQuery();
                    }
                }
                else
                {
                    string sql = @"UPDATE orders SET order_date=@od, delivery_date=@dd, pickup_point=@pp, status_id=@sid, client_id=@cid
                                   WHERE order_id=@id";
                    using (SqlCommand cmd = new SqlCommand(sql, conn))
                    {
                        cmd.Parameters.AddWithValue("@id", orderId);
                        cmd.Parameters.AddWithValue("@od", dtpOrderDate.Value);
                        cmd.Parameters.AddWithValue("@dd", delivery.HasValue ? (object)delivery.Value : DBNull.Value);
                        cmd.Parameters.AddWithValue("@pp", txtPickupPoint.Text);
                        cmd.Parameters.AddWithValue("@sid", (int)cmbStatus.SelectedValue);
                        cmd.Parameters.AddWithValue("@cid", (int)cmbClient.SelectedValue);
                        cmd.ExecuteNonQuery();
                    }
                }
            }
            MessageBox.Show("Сохранено.", "Успех", MessageBoxButtons.OK, MessageBoxIcon.Information);
            this.Close();
        }
    }
}
