csharp
using System;
using System.Collections.Generic;
using System.Data.SqlClient;
using System.Drawing;
using System.IO;
using System.Linq;
using System.Windows.Forms;

namespace ExamApp
{
    public partial class MainForm : Form
    {
        private const string ConnString = "Data Source=YOUR_SERVER;Initial Catalog=DEE2;Integrated Security=True;Encrypt=False";

        // Количество карточек на одной странице (пагинация)
        private readonly int pageSize = 3;
        private int currentPage = 0;

        private FlowLayoutPanel flowPanel;
        private TextBox txtSearch;
        private ComboBox cmbSort, cmbFilter;
        private Button btnLogout, btnAddProduct, btnOrders, btnPrev, btnNext;
        private Label lblUser, lblPageInfo;
        private List<Product> allProducts = new List<Product>();
        private List<Product> filteredProducts = new List<Product>();

        public MainForm()
        {
            InitializeComponents();
            LoadProducts();
        }

        // Динамическое создание интерфейса (панели, кнопки, поля)
        private void InitializeComponents()
        {
            this.Text = "Список товаров";
            this.Size = new Size(1100, 750);
            this.StartPosition = FormStartPosition.CenterScreen;

            // Верхняя панель с кнопками и ФИО
            Panel topPanel = new Panel { Dock = DockStyle.Top, Height = 80, BackColor = Color.LightSeaGreen };
            btnLogout = new Button { Text = "Выйти", Location = new Point(10, 25), Size = new Size(80, 35) };
            btnLogout.Click += (s, e) => this.Close();

            lblUser = new Label
            {
                Text = UserSession.FullName,
                Location = new Point(this.Width - 150, 25),
                Size = new Size(140, 35),
                TextAlign = ContentAlignment.MiddleRight
            };

            btnAddProduct = new Button
            {
                Text = "Добавить товар",
                Location = new Point(200, 25),
                Size = new Size(120, 35),
                Visible = (UserSession.CurrentRole == UserSession.Role.admin)
            };
            btnAddProduct.Click += (s, e) => { new ProductForm(0).ShowDialog(); LoadProducts(); };

            btnOrders = new Button
            {
                Text = "Заказы",
                Location = new Point(340, 25),
                Size = new Size(100, 35),
                Visible = (UserSession.CurrentRole == UserSession.Role.manager || UserSession.CurrentRole == UserSession.Role.admin)
            };
            btnOrders.Click += (s, e) => new OrdersForm().ShowDialog();

            topPanel.Controls.Add(btnLogout);
            topPanel.Controls.Add(lblUser);
            topPanel.Controls.Add(btnAddProduct);
            topPanel.Controls.Add(btnOrders);

            // Панель поиска/сортировки/фильтра (только для менеджера/админа)
            Panel searchPanel = new Panel { Dock = DockStyle.Top, Height = 50, BackColor = Color.LightGray };
            if (UserSession.CurrentRole == UserSession.Role.manager || UserSession.CurrentRole == UserSession.Role.admin)
            {
                Label lblSearch = new Label { Text = "Поиск:", Location = new Point(10, 15), Size = new Size(50, 25) };
                txtSearch = new TextBox { Location = new Point(60, 12), Size = new Size(200, 25) };
                txtSearch.TextChanged += (s, e) => { currentPage = 0; ApplyFilters(); };

                Label lblSort = new Label { Text = "Сортировка:", Location = new Point(290, 15), Size = new Size(80, 25) };
                cmbSort = new ComboBox
                {
                    Location = new Point(370, 12),
                    Size = new Size(150, 25),
                    DropDownStyle = ComboBoxStyle.DropDownList
                };
                cmbSort.Items.AddRange(new[] { "По умолчанию", "Название (А-Я)", "Название (Я-А)", "Цена (возр.)", "Цена (убыв.)" });
                cmbSort.SelectedIndex = 0;
                cmbSort.SelectedIndexChanged += (s, e) => { currentPage = 0; ApplyFilters(); };

                Label lblFilter = new Label { Text = "Фильтр (скидка):", Location = new Point(560, 15), Size = new Size(100, 25) };
                cmbFilter = new ComboBox
                {
                    Location = new Point(660, 12),
                    Size = new Size(150, 25),
                    DropDownStyle = ComboBoxStyle.DropDownList
                };
                cmbFilter.Items.AddRange(new[] { "Все диапазоны", "0 - 11.99%", "12 - 18.99%", "19% и более" });
                cmbFilter.SelectedIndex = 0;
                cmbFilter.SelectedIndexChanged += (s, e) => { currentPage = 0; ApplyFilters(); };

                searchPanel.Controls.Add(lblSearch); searchPanel.Controls.Add(txtSearch);
